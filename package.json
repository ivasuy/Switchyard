{
  "name": "switchyard",
  "version": "0.0.0",
  "private": true,
  "description": "Deploy-anywhere agent runtime gateway for many agent runtimes and wrappers.",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "release:smoke-local": "pnpm --filter @switchyard/cli release:smoke-local"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "fastify": "^5.8.5"
  }
}
