{
  "name": "switchyard",
  "version": "0.0.0",
  "private": true,
  "description": "Deploy-anywhere agent runtime gateway for many agent runtimes and wrappers.",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "release:smoke-local": "pnpm --filter @switchyard/cli release:smoke-local",
    "self-hosted:smoke": "tsx scripts/self-hosted-smoke.ts",
    "sandbox:smoke": "tsx scripts/hosted-sandbox-smoke.ts",
    "production:sandbox-smoke": "tsx scripts/hosted-sandbox-smoke.ts",
    "hosted-real-runtime:smoke": "tsx scripts/hosted-real-runtime-smoke.ts",
    "production:preflight": "tsx scripts/production-preflight.ts",
    "production:migrate": "tsx scripts/production-migrate.ts",
    "production:canary": "tsx scripts/production-canary.ts",
    "production:provider-runtime-canary": "tsx scripts/production-canary.ts --runtime-mode codex.exec_json --confirm-provider-spend"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "fastify": "^5.8.5"
  }
}
