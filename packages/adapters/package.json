    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@switchyard/contracts": "workspace:*",
    "@switchyard/core": "workspace:*",
    "@switchyard/protocol-acpx": "workspace:*",
    "@switchyard/testkit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
