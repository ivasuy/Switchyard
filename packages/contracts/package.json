{
  "name": "@switchyard/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "openapi.local-daemon.json",
    "openapi.hosted-server.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "openapi:generate": "tsx src/openapi-cli.ts generate",
    "openapi:check": "tsx src/openapi-cli.ts check",
    "openapi:generate:hosted": "tsx src/openapi-cli.ts generate --surface hosted_server",
    "openapi:check:hosted": "tsx src/openapi-cli.ts check --surface hosted_server"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
