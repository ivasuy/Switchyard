    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@switchyard/contracts": "workspace:*",
    "@switchyard/core": "workspace:*",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.45.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.15.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
