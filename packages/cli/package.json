{
  "name": "@switchyard/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "switchyard": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm --filter @switchyard/cli... build && vitest run",
    "typecheck": "pnpm --filter @switchyard/daemon build && pnpm --filter @switchyard/sdk build && tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "release:smoke-local": "tsx src/release-smoke-local.ts"
  },
  "dependencies": {
    "@switchyard/adapters": "workspace:*",
    "@switchyard/contracts": "workspace:*",
    "@switchyard/daemon": "workspace:*",
    "@switchyard/sdk": "workspace:*"
  }
}
