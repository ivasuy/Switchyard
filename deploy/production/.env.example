SWITCHYARD_DEPLOYMENT_MODE=production
SWITCHYARD_SERVER_AUTH_MODE=api_key
SWITCHYARD_CONTROL_PLANE_STORE=postgres
SWITCHYARD_HOSTED_RUNTIME_ALLOWLIST=fake.deterministic
SWITCHYARD_HOSTED_REAL_RUNTIME_EXECUTION=disabled
SWITCHYARD_SANDBOX_REAL_EXECUTION=disabled
SWITCHYARD_OBJECT_STORE_PROBE=write_read_delete
SWITCHYARD_PUBLIC_METRICS=0

SWITCHYARD_HOST=0.0.0.0
SWITCHYARD_PORT=4646
SWITCHYARD_POSTGRES_URL=postgres://switchyard:replace-with-postgres-password@postgres:5432/switchyard
SWITCHYARD_REDIS_URL=redis://:replace-with-redis-password@redis:6379/0
SWITCHYARD_NODE_SHARED_TOKEN=replace-with-32-char-node-shared-token
SWITCHYARD_API_KEY_PEPPER=replace-with-32-char-api-key-pepper

SWITCHYARD_CONTROL_PLANE_BOOTSTRAP_PATH=/run/secrets/replace-with-bootstrap-file
SWITCHYARD_OBJECT_STORE_BACKEND=s3-compatible
SWITCHYARD_OBJECT_STORE_ENDPOINT=https://replace-with-object-store-endpoint
SWITCHYARD_OBJECT_STORE_REGION=replace-with-object-store-region
SWITCHYARD_OBJECT_STORE_BUCKET=replace-with-object-store-bucket
SWITCHYARD_OBJECT_STORE_ACCESS_KEY_ID=replace-with-object-store-access-key-id
SWITCHYARD_OBJECT_STORE_SECRET_ACCESS_KEY=replace-with-object-store-secret-access-key
SWITCHYARD_OBJECT_STORE_FORCE_PATH_STYLE=true
SWITCHYARD_OBJECT_STORE_KEY_PREFIX=replace-with-object-store-prefix
SWITCHYARD_OBJECT_STORE_REQUEST_TIMEOUT_MS=5000

SWITCHYARD_SERVER_URL=https://replace-with-public-server-url
SWITCHYARD_NODE_CAPABILITIES=runtime.fake.deterministic
SWITCHYARD_NODE_ALLOW_RUNTIME_MODES=fake.deterministic
SWITCHYARD_NODE_ALLOW_CWD_PREFIXES=/srv/switchyard/work

SWITCHYARD_POSTGRES_DB=switchyard
SWITCHYARD_POSTGRES_USER=switchyard
SWITCHYARD_POSTGRES_PASSWORD=replace-with-local-postgres-container-password

# Optional R21 provider runtime activation (default remains fake-only/no-spend):
# SWITCHYARD_HOSTED_RUNTIME_ALLOWLIST=fake.deterministic,codex.exec_json
# SWITCHYARD_HOSTED_REAL_RUNTIME_EXECUTION=enabled
# SWITCHYARD_PROVIDER_RUNTIME_POLICY_PATH=/run/secrets/provider-runtime-policy.json
# OPENAI_API_KEY=replace-with-openai-api-key
# ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# OPENCODE_CONFIG_DIR=/srv/switchyard/opencode
# Provider policy spend controls are set in provider-runtime-policy.json:
#   maxActiveRuns, maxRunsPerHour, maxRunTimeoutSeconds, maxPromptBytes
